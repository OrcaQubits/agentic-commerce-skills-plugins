{
  "description": "WebMCP plugin hooks — async secret detection on code writes",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_secrets.py\"",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
