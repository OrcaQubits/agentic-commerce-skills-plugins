{
  "description": "WooCommerce plugin hooks — destructive WP-CLI protection + async secret detection",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_woo_commands.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_secrets.py\"",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
